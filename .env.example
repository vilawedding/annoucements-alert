# ==================== TELEGRAM CONFIGURATION ====================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ==================== EXCHANGE MONITORING ====================
# Enable/disable exchange monitoring
BINANCE_ENABLED=true
UPBIT_ENABLED=true

# Check intervals (milliseconds)
BINANCE_INTERVAL=500
UPBIT_INTERVAL=500

# Health server port
PORT=3003

# ==================== AUTO-TRADING ====================
# Enable/disable auto-trading feature
AUTO_TRADE_ENABLED=false

# Trade on Upbit listing announcements
AUTO_TRADE_UPBIT_LISTING=true

# Trade on Binance listing announcements
AUTO_TRADE_BINANCE_LISTING=true

# Trade amount in USDT per position
AUTO_TRADE_AMOUNT=10

# Leverage for futures trading (1-125x)
AUTO_TRADE_LEVERAGE=5

AUTO_TRADE_SL_PERCENT=1.0          # Stop Loss %
AUTO_TRADE_TP_PERCENT=200.0        # Take Profit % (fallback)
AUTO_TRADE_TP_PERCENT_UPBIT=200.0
AUTO_TRADE_TP_PERCENT_BINANCE=200.0

# ==================== BINANCE FUTURES API ====================
# Get API keys from:
# - Production: https://www.binance.com/en/my/settings/api-management
# - Testnet: https://testnet.binancefuture.com/

BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# Use testnet for safety (recommended for testing)
# true = testnet, false = production
BINANCE_USE_TESTNET=true
