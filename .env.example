# ==================== TELEGRAM CONFIGURATION ====================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ==================== EXCHANGE MONITORING ====================
# Enable/disable exchange monitoring
BINANCE_ENABLED=true
UPBIT_ENABLED=true
BITHUMB_ENABLED=false

# Check intervals (milliseconds)
BINANCE_INTERVAL=500
UPBIT_INTERVAL=500
BITHUMB_INTERVAL=200

# Bithumb notice feed (default already set in config)
BITHUMB_API_URL=https://feed.bithumb.com/_next/data/NLILjNtdG9PdJyIGBALYd/notice.json?category=9&page=1

# Optional: if server IP is blocked by Cloudflare (403), copy cf_clearance cookie from browser session
BITHUMB_CF_CLEARANCE=

# Optional: full Cookie header from successful browser request (preferred when 403 persists)
# Example format: key1=value1; key2=value2; cf_clearance=...
BITHUMB_COOKIE=

# Health server port
PORT=3003

# ==================== AUTO-TRADING ====================
# Enable/disable auto-trading feature
AUTO_TRADE_ENABLED=false

# Trade on Upbit listing announcements
AUTO_TRADE_UPBIT_LISTING=true

# Trade on Bithumb listing announcements
AUTO_TRADE_BITHUMB_LISTING=true

# Trade on Binance listing announcements
AUTO_TRADE_BINANCE_LISTING=true

# Trade on Binance delisting announcements (SHORT)
AUTO_TRADE_BINANCE_DELISTING=true

# Trade amount in USDT per position
AUTO_TRADE_AMOUNT=10

# Leverage for futures trading (1-125x)
AUTO_TRADE_LEVERAGE=5

AUTO_TRADE_SL_PERCENT=1.0          # Stop Loss %
AUTO_TRADE_TP_PERCENT=200.0        # Take Profit % (fallback)
AUTO_TRADE_TP_PERCENT_UPBIT=200.0
AUTO_TRADE_TP_PERCENT_BITHUMB=200.0
AUTO_TRADE_TP_PERCENT_BINANCE=200.0

# Execute MARKET first, then place TP/SL asynchronously for lower entry latency
AUTO_TRADE_MARKET_FIRST_ASYNC_PROTECTION=true

# Retry settings
# 1 = retry 1 time (total 2 attempts)
AUTO_TRADE_RETRY_COUNT=1
AUTO_TRADE_RETRY_DELAY_MS=50

# ==================== BINANCE FUTURES API ====================
# Get API keys from:
# - Production: https://www.binance.com/en/my/settings/api-management
# - Testnet: https://testnet.binancefuture.com/

BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# Use testnet for safety (recommended for testing)
# true = testnet, false = production
BINANCE_USE_TESTNET=true
