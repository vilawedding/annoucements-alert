{
  "name": "crypto-monitor-bot",
  "version": "3.0.0",
  "description": "Multi-exchange cryptocurrency listing/delisting monitor with lightning-fast trading",
  "main": "index-new.js",
  "scripts": {
    "start": "node --require ./preload.js index-new.js",
    "dev": "nodemon --require ./preload.js index-new.js",
    "start:legacy": "node --require ./preload.js scripts/legacy/index-monolithic.js",
