    "test:auto-trade": "node --require ./preload.js scripts/tests/test-auto-trade.js",
    "example:binance": "node scripts/examples/binance-example.js"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cheerio": "^1.0.0-rc.12",
    "dotenv": "^16.3.0",
    "node-telegram-bot-api": "^0.61.0",
    "undici": "5.28.2"
  }
}
